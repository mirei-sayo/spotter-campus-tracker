{
  "builds": [
    { "src": "server/main.py", "use": "@vercel/python" },
    { "src": "client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/main.py" },
    { "src": "/(.*)", "dest": "client/$1" }
  ],
  "crons": [
    { "path": "/api/cron/expire", "schedule": "0 0 * * *" }
  ]
}
